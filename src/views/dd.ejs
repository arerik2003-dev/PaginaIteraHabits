<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Itera Habits | Pro</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="main-container">
        <div class="content-left">
            <img src="/img/logo.png" alt="Logo" class="logo">
            <h1 class="title">Itera Habits</h1>
            <p class="subtitle">Personal Habit Tracker App</p>
            <div class="badge">30+ Activity Screens</div>
            
            <div class="store-buttons">
                <img src="/img/google-play.png" alt="Google Play">
                <img src="/img/app-store.png" alt="App Store">
            </div>
        </div>

        <div class="content-right">
            <div class="perspective-wrapper">
                <div class="phone-column">
                    <img src="/img/screen1.jpg" alt="App Screen" class="phone-img">
                    <img src="/img/screen2.jpg" alt="App Screen" class="phone-img">
                </div>
                <div class="phone-column offset">
                    <img src="/img/screen3.jpg" alt="App Screen" class="phone-img">
                    <img src="/img/screen4.jpg" alt="App Screen" class="phone-img">
                </div>
            </div>
        </div>
    </div>
</body>
</html>